python3 << 'PYEOF'
# Generate SVG icons as PNG-like SVGs
icon_svg = '''<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <rect width="512" height="512" rx="80" fill="#0a0a0f"/>
  <rect width="512" height="512" rx="80" fill="url(#g)"/>
  <defs>
    <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#e94560"/>
      <stop offset="100%" stop-color="#f5a623"/>
    </linearGradient>
  </defs>
  <text x="256" y="320" font-family="Arial Black" font-size="280" text-anchor="middle" fill="white">💪</text>
</svg>'''
with open('/mnt/user-data/outputs/mehdi-tracker/icon.svg', 'w') as f:
    f.write(icon_svg)
print("icon done")
PYEOF